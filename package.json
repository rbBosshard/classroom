{
    "name": "classroom-platform",
    "version": "1.0.0",
    "type": "module",
    "description": "Interactive classroom learning platform with Vue.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:vercel": "vite build --config vite.config.vercel.ts",
