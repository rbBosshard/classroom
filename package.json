        "@types/node": "^24.9.2",
        "@vitejs/plugin-vue": "^4.6.2",
        "@vue/tsconfig": "^0.8.1",
        "autoprefixer": "^10.4.16",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.3.5",
        "typescript": "^5.9.3",
        "vite": "^4.5.0",
        "vue-tsc": "^1.8.27"
    }
}